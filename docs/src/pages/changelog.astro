        description:
          "The first commit established the core solution and HTTP client that became the foundation for every subsequent release.",
        references: [c("e267367cd0f159560dc48a9d7103b5a603d327f3")],
      },
      {
        title: "Added the first Minimal API sample",
        description:
          "A runnable sample showed how to register and expose the client from ASP.NET Core's then-new Minimal API programming model.",
        references: [c("ac9c3dca42ce6c22dd979961fcd620f678b0463e")],
      },
      {
        title: "Published the initial public preview",
        description:
          "Release 0.0.4 marked the first documented NuGet-ready version after the repository's build and publishing foundations were proven.",
        references: [rel("0.0.4"), c("5438d5e001cc5b586932f6407b356966187e1b1b")],
      },
    ],
  },
];

const periodCount = periods.length;
const entryCount = periods.reduce((count, period) => count + period.changes.length, 0);
---

<Layout
  title="Changelog - pwned.client"
  description="The complete history of pwned.client, with release notes and links to the commits, pull requests, and issues behind every milestone."
  currentPath={Astro.url.pathname}
>
  <header class="changelog-hero">
    <div class="container changelog-hero-grid">
      <div>
        <div class="eyebrow">Project history &middot; 2021-present</div>
        <h1 class="display">Built in public,<br /><span class="accent-word">change by change.</span></h1>
        <p class="lead">
          A complete, curated account of the client from its first commit through today,
          grounded in the releases, pull requests, issues, and commit history that shipped it.
        </p>
      </div>
      <dl class="history-stats" aria-label="Changelog coverage">
        <div><dt>139</dt><dd>mainline commits reviewed</dd></div>
        <div><dt>30</dt><dd>merged pull requests</dd></div>
        <div><dt>15</dt><dd>GitHub releases</dd></div>
        <div><dt>{entryCount}</dt><dd>explained changes</dd></div>
      </dl>
    </div>
  </header>

  <div class="container changelog-shell">
    <aside class="changelog-index" aria-label="Changelog releases">
      <p>Jump to</p>
      <nav>
        {periods.map((period) => (
          <a href={`#${period.id}`}>
            <span>{period.version}</span>
            <small>{period.date.split(" ").at(-1)}</small>
          </a>
        ))}
      </nav>
    </aside>

    <main class="changelog-content">
      <section class="coverage-note" aria-labelledby="coverage-title">
        <i class="ph ph-info" aria-hidden="true"></i>
        <div>
          <h2 id="coverage-title">What “complete” means here</h2>
          <p>
            This timeline covers all {periodCount} release eras on the main branch and every merged pull request.
            The repository has no standalone issues; the linked NuGet issue is the only external issue that directly
            shaped a shipped workaround. Closed, unmerged dependency proposals are not presented as delivered changes.
          </p>
        </div>
      </section>

      {periods.map((period) => (
        <section class="release-period" id={period.id}>
          <div class="release-heading">
            <div>
              <p class="release-date">{period.date}</p>
              <h2>
                {period.href ? <a href={period.href}>{period.version}</a> : period.version}
              </h2>
            </div>
            <span class:list={["status", `status-${period.status}`]}>
              {period.status === "current" ? "Unreleased" : period.status}
            </span>
          </div>
          <p class="release-summary">{period.summary}</p>

          <div class="change-list">
            {period.changes.map((change) => (
              <article class="change">
                <span class="change-marker" aria-hidden="true"></span>
                <div>
                  <h3>{change.title}</h3>
                  <p>{change.description}</p>
                  <div class="references" aria-label={`References for ${change.title}`}>
                    {change.references.map((reference) => (
                      <a href={reference.href} class={`reference reference-${reference.kind}`} rel="noopener">
                        <i
                          class:list={[
                            "ph",
                            reference.kind === "commit" && "ph-git-commit",
                            reference.kind === "pull" && "ph-git-pull-request",
                            reference.kind === "issue" && "ph-record",
                            reference.kind === "release" && "ph-tag",
                            reference.kind === "compare" && "ph-git-diff",
                          ]}
                          aria-hidden="true"
                        ></i>
                        {reference.label}
                      </a>
                    ))}
                  </div>
                </div>
              </article>
            ))}
          </div>
        </section>
      ))}
    </main>
  </div>
</Layout>

<style>
  .changelog-hero {
    position: relative;
    overflow: hidden;
    padding-block: clamp(4rem, 9vw, 7rem);
    border-bottom: 1px solid var(--line);
    background:
      radial-gradient(circle at 82% 18%, var(--accent-glow), transparent 28rem),
      linear-gradient(180deg, var(--surface-raised), var(--surface));
  }

  .changelog-hero::after {
    content: "git log";
    position: absolute;
    right: -0.04em;
    bottom: -0.38em;
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: clamp(6rem, 18vw, 15rem);
    font-weight: 600;
    opacity: 0.035;
    pointer-events: none;
  }

  .changelog-hero-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(18rem, 0.65fr);
    gap: clamp(3rem, 8vw, 7rem);
    align-items: end;
  }

  .changelog-hero h1 {
    margin-block: 1rem 1.5rem;
    font-size: clamp(3rem, 7vw, 6rem);
  }

  .history-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    margin: 0;
    border: 1px solid var(--line);
    border-radius: var(--r-card);
    background: color-mix(in srgb, var(--surface-raised) 88%, transparent);
    box-shadow: var(--shadow-md);
    overflow: hidden;
  }

  .history-stats div {
    padding: 1.4rem;
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .history-stats div:nth-child(even) {
    border-right: 0;
  }

  .history-stats div:nth-child(n + 3) {
    border-bottom: 0;
  }

  .history-stats dt {
    color: var(--accent);
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 700;
    line-height: 1;
  }

  .history-stats dd {
    margin: 0.45rem 0 0;
    color: var(--ink-muted);
    font-size: 0.78rem;
    line-height: 1.35;
  }

  .changelog-shell {
    display: grid;
    grid-template-columns: 12rem minmax(0, 1fr);
    gap: clamp(2.5rem, 7vw, 6.5rem);
    padding-block: clamp(3.5rem, 7vw, 6rem);
  }

  .changelog-index {
    position: sticky;
    top: 6rem;
    height: fit-content;
    max-height: calc(100vh - 8rem);
    overflow: auto;
  }

  .changelog-index > p {
    margin-bottom: 0.75rem;
    color: var(--ink-muted);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .changelog-index nav {
    display: grid;
    border-left: 1px solid var(--line);
  }

  .changelog-index a {
    display: flex;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.45rem 0 0.45rem 0.85rem;
    border-left: 2px solid transparent;
    color: var(--ink-muted);
    font-size: 0.8rem;
    transition: border-color 160ms ease, color 160ms ease;
  }

  .changelog-index a:hover {
    border-left-color: var(--accent);
    color: var(--accent);
  }

  .changelog-index small {
    font-family: var(--font-mono);
    font-size: 0.65rem;
  }

  .changelog-content {
    min-width: 0;
  }

  .coverage-note {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1rem;
    margin-bottom: 4rem;
    padding: 1.25rem 1.4rem;
    border: 1px solid color-mix(in srgb, var(--accent) 30%, var(--line));
    border-radius: var(--r-card);
    background: var(--accent-tint);
  }

  .coverage-note > i {
    color: var(--accent);
    font-size: 1.35rem;
  }

  .coverage-note h2 {
    margin-bottom: 0.35rem;
    font-size: 1rem;
    line-height: 1.3;
  }

  .coverage-note p {
    color: var(--ink-soft);
    font-size: 0.88rem;
    line-height: 1.65;
  }

  .release-period {
    scroll-margin-top: 6rem;
    padding-bottom: clamp(4rem, 8vw, 6rem);
  }

  .release-period + .release-period {
    padding-top: clamp(3rem, 6vw, 5rem);
    border-top: 1px solid var(--line);
  }

  .release-heading {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .release-date {
    margin-bottom: 0.45rem;
    color: var(--ink-muted);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .release-heading h2 {
    font-size: clamp(2rem, 5vw, 3.2rem);
  }

  .release-heading h2 a:hover {
    color: var(--accent);
  }

  .status {
    flex: none;
    padding: 0.35rem 0.7rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--ink-muted);
    background: var(--surface-raised);
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .status-current {
    border-color: color-mix(in srgb, var(--accent) 45%, transparent);
    color: var(--accent-strong);
    background: var(--accent-tint);
  }

  .status-preview {
    border-style: dashed;
  }

  .release-summary {
    max-width: 68ch;
    margin-top: 1rem;
    color: var(--ink-soft);
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .change-list {
    position: relative;
    display: grid;
    gap: 2rem;
    margin-top: 2.5rem;
  }

  .change-list::before {
    content: "";
    position: absolute;
    top: 0.55rem;
    bottom: 0.55rem;
    left: 0.3rem;
    width: 1px;
    background: var(--line-strong);
  }

  .change {
    position: relative;
    display: grid;
    grid-template-columns: 0.65rem minmax(0, 1fr);
    gap: 1.2rem;
  }

  .change-marker {
    z-index: 1;
    width: 0.65rem;
    height: 0.65rem;
    margin-top: 0.48rem;
    border: 2px solid var(--surface);
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 1px var(--accent);
  }

  .change h3 {
    font-size: 1.1rem;
    line-height: 1.35;
    letter-spacing: -0.015em;
  }

  .change p {
    max-width: 74ch;
    margin-top: 0.45rem;
    color: var(--ink-soft);
    font-size: 0.92rem;
    line-height: 1.7;
  }

  .references {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-top: 0.85rem;
  }

  .reference {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.26rem 0.5rem;
    border: 1px solid var(--line);
    border-radius: 6px;
    color: var(--ink-muted);
    background: var(--surface-raised);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 600;
    transition: border-color 160ms ease, color 160ms ease, transform 160ms ease;
  }

  .reference:hover {
    border-color: var(--accent);
    color: var(--accent);
    transform: translateY(-1px);
  }

  .reference-pull {
    color: var(--accent-strong);
    background: var(--accent-tint);
  }

  .reference-issue {
    color: #9a6700;
    background: color-mix(in srgb, #d29922 12%, var(--surface-raised));
  }

  [data-theme="dark"] .reference-issue {
    color: #e3b341;
  }

  @media (max-width: 900px) {
    .changelog-hero-grid {
      grid-template-columns: 1fr;
    }

    .history-stats {
      max-width: 34rem;
    }

    .changelog-shell {
      grid-template-columns: 1fr;
    }

    .changelog-index {
      position: static;
      max-height: none;
      overflow: visible;
    }

    .changelog-index nav {
      display: flex;
      gap: 0.45rem;
      padding-bottom: 0.5rem;
      border-left: 0;
      overflow-x: auto;
      scrollbar-width: thin;
    }

    .changelog-index a {
      flex: none;
      gap: 0.45rem;
      padding: 0.45rem 0.65rem;
      border: 1px solid var(--line);
      border-radius: 7px;
      background: var(--surface-raised);
    }
  }

  @media (max-width: 560px) {
    .changelog-hero-grid {
      gap: 2.5rem;
    }

    .history-stats div {
      padding: 1.1rem;
    }

    .release-heading {
      align-items: flex-start;
    }

    .status {
      margin-top: 1.7rem;
    }

    .coverage-note {
      grid-template-columns: 1fr;
    }
  }
</style>
