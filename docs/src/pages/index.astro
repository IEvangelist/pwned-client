---
import Layout from "../layouts/Layout.astro";
import CodeBlock from "../components/CodeBlock.astro";

const base = import.meta.env.BASE_URL;

const heroCode = `// The plaintext never leaves your process.
var pwned = await passwordsClient
    .GetPwnedPasswordAsync("P@ssw0rd!");

if (pwned.IsPwned is true)
{
    logger.LogWarning(
        "Seen {Count:N0} times in breaches.",
        pwned.PwnedCount);
}`;

const registrationCode = `builder.Services.AddPwnedServices(options =>
{
    options.ApiKey = builder.Configuration["HibpOptions:ApiKey"];
    options.UserAgent = "my-service/1.0";
});

// Resolve a focused client, or the aggregate IPwnedClient.
var breaches = app.Services
    .GetRequiredService<IPwnedBreachesClient>();`;

const packages = [
  ["HaveIBeenPwned.Client", "The full client with focused interfaces and sensible defaults.", true],
  ["HaveIBeenPwned.Client.Abstractions", "Contracts and models for clean dependency boundaries.", false],
  ["HaveIBeenPwned.Client.PollyExtensions", "Resilience with retry-after, jitter, and circuit breaking.", false],
];
---

<Layout
  title="pwned.client - the .NET client for Have I Been Pwned"
  description="A practical, AOT-compatible .NET client for the complete Have I Been Pwned REST API v3, with privacy-first password checks."
>
  <!-- 1. HERO: asymmetric split -->
  <section class="hero">
    <div class="hero-ghost" aria-hidden="true">';--</div>
    <div class="container hero-grid">
      <div class="hero-enter">
        <div class="eyebrow">.NET client &middot; HIBP API v3</div>
        <h1 class="display">Know what's been <span class="accent-word">pwned</span>.<span class="caret" aria-hidden="true"></span></h1>
        <p class="lead">A complete, AOT-compatible client for Have I Been Pwned, with clean interfaces and privacy-first password checks.</p>
        <div class="hero-cta">
          <a class="button button-primary" href={`${base}docs/`}>
            <i class="ph ph-book-open-text" aria-hidden="true"></i> Read the API docs
          </a>
          <a class="button button-secondary" href="https://www.nuget.org/packages/HaveIBeenPwned.Client" rel="noopener">
            <i class="ph ph-download-simple" aria-hidden="true"></i> Install from NuGet
          </a>
        </div>
      </div>
      <div class="hero-visual">
        <div class="editor">
          <div class="editor-bar" aria-hidden="true">
            <span class="editor-dot"></span>
            <span class="editor-dot"></span>
            <span class="editor-dot"></span>
            <span class="editor-name">PasswordCheck.cs</span>
          </div>
          <CodeBlock code={heroCode} bare />
        </div>
      </div>
    </div>
  </section>

  <!-- 2. INSTALL BAND: full-width horizontal -->
  <section class="install-band">
    <div class="container install-row">
      <div class="install-cmd">
        <span class="prompt" aria-hidden="true">$</span>
        <code>dotnet add package HaveIBeenPwned.Client</code>
        <button class="copy-btn" type="button" data-copy="dotnet add package HaveIBeenPwned.Client" aria-label="Copy install command">
          <i class="ph ph-copy" aria-hidden="true"></i>
          <span data-copy-label>Copy</span>
        </button>
      </div>
      <div class="facts">
        <div class="fact"><strong>AOT</strong><span>trim-ready</span></div>
        <div class="fact"><strong>3</strong><span>packages</span></div>
        <div class="fact"><strong>MIT</strong><span>licensed</span></div>
        <div class="fact"><strong>OTel</strong><span>instrumented</span></div>
      </div>
    </div>
  </section>

  <!-- 3. CAPABILITIES: asymmetric bento -->
  <section class="section">
    <div class="container">
      <div class="sec-head">
        <div class="eyebrow">Every surface of the API</div>
        <h2 class="display">One package. Four ways to see exposure.</h2>
      </div>
      <div class="bento">
        <a class="cell cell-lg" data-reveal href={`${base}docs/breaches/`}>
          <div>
            <span class="cell-icon"><i class="ph ph-door-open" aria-hidden="true"></i></span>
            <h3>Breach intelligence</h3>
            <p>Search an account, browse the full breach catalogue, and inspect the data classes exposed in each incident.</p>
            <div class="cell-methods">
              <span class="method-chip">GetBreachesAsync</span>
              <span class="method-chip">GetBreachesForAccountAsync</span>
              <span class="method-chip">k-anonymity</span>
            </div>
          </div>
          <span class="cell-link">Breaches reference <i class="ph ph-arrow-up-right" aria-hidden="true"></i></span>
        </a>

        <a class="cell cell-sm" data-reveal href={`${base}docs/passwords/`}>
          <span class="cell-icon"><i class="ph ph-key" aria-hidden="true"></i></span>
          <h3>Pwned passwords</h3>
          <p>SHA-1 or NTLM range queries. The plaintext stays on your machine.</p>
          <span class="cell-link">Passwords <i class="ph ph-arrow-up-right" aria-hidden="true"></i></span>
        </a>

        <a class="cell cell-sm" data-reveal href={`${base}docs/domains/`}>
          <span class="cell-icon"><i class="ph ph-globe-hemisphere-west" aria-hidden="true"></i></span>
          <h3>Domains &amp; stealer logs</h3>
          <p>Verify domains over DNS or email, then search exposure by address.</p>
          <span class="cell-link">Domains <i class="ph ph-arrow-up-right" aria-hidden="true"></i></span>
        </a>

        <a class="cell cell-wide" data-reveal href={`${base}docs/telemetry/`}>
          <span class="cell-icon"><i class="ph ph-chart-line-up" aria-hidden="true"></i></span>
          <div class="cell-body">
            <h3>Telemetry, ready to wire</h3>
            <p>A stable ActivitySource and Meter drop straight into your existing OpenTelemetry pipeline.</p>
          </div>
          <div class="cell-methods">
            <span class="method-chip">request.duration</span>
            <span class="method-chip">rate_limit.count</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- 4. K-ANONYMITY: animated SDK walkthrough -->
  <section class="section password-preview-section" data-password-preview>
    <div class="container password-preview-grid">
      <div class="password-preview-copy">
        <div class="eyebrow">Privacy, made visible</div>
        <h2 class="display">The password check that <span class="accent-word">never sends</span> the password.</h2>
        <p>K-anonymity means the SDK hashes the password in your process, sends only five SHA-1 characters, then finds the match locally.</p>
        <a class="button button-secondary" href={`${base}docs/passwords/`}>
          <i class="ph ph-key" aria-hidden="true"></i> Explore password checks
        </a>
      </div>

      <div class="password-preview-flow" aria-label="Animated password check walkthrough">
        <div class="password-preview-topline">
          <span><i class="ph ph-lock-key" aria-hidden="true"></i> Plaintext stays local</span>
          <button class="password-preview-replay" type="button" data-password-replay>
            <i class="ph ph-arrow-clockwise" aria-hidden="true"></i> Replay
          </button>
        </div>
        <div class="password-preview-input">
          <span>Password entered</span>
          <code>••••••••••••</code>
          <i class="ph ph-eye-slash" aria-hidden="true"></i>
        </div>
        <p class="password-preview-status" data-password-status aria-live="polite">
          <span aria-hidden="true"></span>
          <span data-password-message>Ready to protect the password.</span>
        </p>
        <ol class="password-preview-steps">
          <li data-preview-step="hash" data-state="pending">
            <span class="password-preview-marker" aria-hidden="true">01</span>
            <div>
              <span>Inside your process</span>
              <strong>Hash the password</strong>
            </div>
            <code><mark>21BD1</mark><b>2DC183F...A757</b></code>
          </li>
          <li data-preview-step="prefix" data-state="pending">
            <span class="password-preview-marker" aria-hidden="true">02</span>
            <div>
              <span>Across the network</span>
              <strong>Request the range</strong>
            </div>
            <code><b>GET /range/</b><mark>21BD1</mark></code>
          </li>
          <li data-preview-step="range" data-state="pending">
            <span class="password-preview-marker" aria-hidden="true">03</span>
            <div>
              <span>Anonymous response</span>
              <strong>Receive a suffix bucket</strong>
            </div>
            <div class="password-preview-range" aria-label="Range response">
              <i></i><i></i><i></i><small>800+ suffixes</small>
            </div>
          </li>
          <li data-preview-step="compare" data-state="pending">
            <span class="password-preview-marker" aria-hidden="true">04</span>
            <div>
              <span>Back inside your process</span>
              <strong>Compare locally</strong>
            </div>
            <code><i class="ph ph-magnifying-glass" aria-hidden="true"></i> suffix match</code>
          </li>
        </ol>
        <div class="password-preview-result" data-password-result hidden>
          <i class="ph ph-shield-check" aria-hidden="true"></i>
          <div><span>SDK result</span><strong>Only the local match is returned.</strong></div>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. REGISTRATION: centered code showcase -->
  <section class="section">
    <div class="container">
      <div class="sec-head">
        <h2 class="display">One registration. Every client.</h2>
        <p>Add the services once. Resolve a focused interface where you need it, or the aggregate <code class="mono" style="color:var(--accent);">IPwnedClient</code> when an integration touches the whole API.</p>
      </div>
      <div class="showcase">
        <CodeBlock label="Program.cs" code={registrationCode} />
        <div class="pkg-legend">
          {packages.map(([name, copy, primary]) => (
            <div class={`pkg${primary ? " is-primary" : ""}`}>
              <div class="pkg-name">{name}</div>
              <p>{copy}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- 6. ERROR BEHAVIOR: split -->
  <section class="section" style="padding-top: 0;">
    <div class="container split">
      <div>
        <h2 class="display" style="font-size: clamp(2rem, 4.2vw, 3.2rem);">Failures stay honest.</h2>
        <p class="muted" style="margin-top: 1rem; max-width: 46ch;">Documented 404 responses map to each operation's no-result shape. Everything else throws a <code class="mono" style="color:var(--accent);">PwnedApiException</code> you can inspect. Cancellation and transport errors never turn into empty success.</p>
        <a class="button button-secondary" href={`${base}docs/`} style="margin-top: 1.75rem;">
          <i class="ph ph-arrow-up-right" aria-hidden="true"></i> Explore the reference
        </a>
      </div>
      <div class="kv" data-reveal>
        <div class="kv-row"><span>exception.StatusCode</span><b>429</b></div>
        <div class="kv-row"><span>exception.RetryAfter</span><b class="ok">respected</b></div>
        <div class="kv-row"><span>exception.ResponseContent</span><b>available</b></div>
        <div class="kv-row"><span>on 404</span><b class="ok">no-result</b></div>
      </div>
    </div>
  </section>

  <!-- 7. CLOSING CTA -->
  <section class="cta-band">
    <div class="cta-ghost" aria-hidden="true">';--</div>
    <div class="container">
      <h2 class="display">Ship breach checks this afternoon.</h2>
      <p class="lead">Focused interfaces, privacy-first helpers, and resilience that behaves. Start with the reference.</p>
      <div class="hero-cta">
        <a class="button button-primary" href={`${base}docs/`}>
          <i class="ph ph-book-open-text" aria-hidden="true"></i> Read the API docs
        </a>
        <a class="button button-secondary" href="https://github.com/IEvangelist/pwned-client" rel="noopener">
          <svg class="gh-mark" viewBox="0 0 16 16" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"></path></svg>
          View on GitHub
        </a>
      </div>
    </div>
  </section>

  <script is:inline>
    const preview = document.querySelector("[data-password-preview]");
    if (preview) {
      const steps = [...preview.querySelectorAll("[data-preview-step]")];
      const message = preview.querySelector("[data-password-message]");
      const result = preview.querySelector("[data-password-result]");
      const replay = preview.querySelector("[data-password-replay]");
      const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      let timers = [];

      const messages = [
        "Hashing the password locally. No network request has been made.",
        "Only the first five hash characters leave the device.",
        "HIBP returns every suffix in the anonymous prefix bucket.",
        "The SDK compares the suffix in memory and returns the local match.",
      ];

      const complete = () => {
        steps.forEach((step) => step.dataset.state = "complete");
        message.textContent = "The password and full hash never left your process.";
        result.hidden = false;
      };

      const play = () => {
        timers.forEach((timer) => window.clearTimeout(timer));
        timers = [];
        result.hidden = true;
        steps.forEach((step) => step.dataset.state = "pending");

        if (reducedMotion) {
          complete();
          return;
        }

        steps.forEach((step, index) => {
          timers.push(window.setTimeout(() => {
            if (index > 0) steps[index - 1].dataset.state = "complete";
            step.dataset.state = "active";
            message.textContent = messages[index];
          }, index * 1050));
        });
        timers.push(window.setTimeout(complete, steps.length * 1050));
      };

      replay.addEventListener("click", play);

      if (reducedMotion || !("IntersectionObserver" in window)) {
        play();
      } else {
        const observer = new IntersectionObserver((entries) => {
          if (entries[0].isIntersecting) {
            play();
            observer.disconnect();
          }
        }, { threshold: 0.35 });
        observer.observe(preview);
      }
    }
  </script>
</Layout>
