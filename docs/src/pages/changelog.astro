import Layout from "../layouts/Layout.astro";

const repo = "https://github.com/IEvangelist/pwned-client";
const commit = (sha: string) => `${repo}/commit/${sha}`;
const pull = (number: number) => `${repo}/pull/${number}`;
const release = (tag: string) => `${repo}/releases/tag/${tag}`;
const tag = (name: string) => `${repo}/tree/${name}`;
const compare = (from: string, to: string) => `${repo}/compare/${from}...${to}`;

interface Reference {
  label: string;
  href: string;
  kind: "commit" | "pull" | "issue" | "release" | "compare";
}

interface Change {
  title: string;
  description: string;
  references: Reference[];
}

interface Period {
  id: string;
  version: string;
  date: string;
  status: "current" | "preview" | "release";
  summary: string;
  href?: string;
  changes: Change[];
}

const c = (sha: string): Reference => ({
  label: sha.slice(0, 7),
  href: commit(sha),
  kind: "commit",
});
const pr = (number: number): Reference => ({
  label: `PR #${number}`,
  href: pull(number),
  kind: "pull",
});
const rel = (name: string, href = release(name)): Reference => ({
  label: name,
  href,
  kind: "release",
});
const diff = (from: string, to: string): Reference => ({
  label: `${from}...${to}`,
  href: compare(from, to),
  kind: "compare",
});

